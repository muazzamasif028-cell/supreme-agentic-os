// API Source
class APIProblemSource extends EventEmitter {
    constructor() {
        super();
        this.name = 'api';
    }
    
    async handleRequest(req) {
        const problem = req.body;
        this.emit('problem', problem);
    }
}

// CLI Source
class CLIProblemSource extends EventEmitter {
    constructor() {
        super();
        this.name = 'cli';
    }
    
    async handleArgv() {
        const args = process.argv.slice(2);
        if (args.length > 0) {
            this.emit('problem', args.join(' '));
        }
    }
}

// File Source
class FileProblemSource extends EventEmitter {
    constructor() {
        super();
        this.name = 'file';
    }
    
    async watchDirectory(dirPath) {
        fs.watch(dirPath, (eventType, filename) => {
            if (filename) {
                const content = fs.readFileSync(path.join(dirPath, filename), 'utf-8');
                this.emit('problem', content);
            }
        });
    }
}

