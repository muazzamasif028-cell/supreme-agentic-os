// ============================================
// MULTI-LANGUAGE CODE ANALYZER
// ============================================
class MultiLanguageAnalyzer {
    
    // Analyze any code in any language
    static async analyze(code, filename = '') {
        // Step 1: Detect language
        const detected = UniversalLanguageDetector.detectLanguage(code);
        const primaryLang = detected[0];
        
        if (!primaryLang || primaryLang.confidence < 30) {
            return {
                error: 'Language not recognized',
                suggestion: 'Provide more code or specify language'
            };
        }
        
        // Step 2: Get language-specific rules
        const rules = UniversalLanguageDetector.getLanguageSpecificRules(primaryLang.language);
        
        // Step 3: Scan for problems
        const problems = [];
        for (const [problemType, pattern] of Object.entries(rules)) {
            const matches = code.match(pattern);
            if (matches && matches.length > 0) {
                problems.push({
                    type: problemType,
                    occurrences: matches.length,
                    language: primaryLang.language,
                    fix: UniversalLanguageDetector.getFixSuggestion(primaryLang.language, problemType),
                    severity: problemType.includes('Error') ? 'HIGH' : 'MEDIUM'
                });
            }
        }
        
        // Step 4: Check common issues across all languages
        const commonIssues = this.checkCommonIssues(code);
        problems.push(...commonIssues);
        
        return {
            language: primaryLang,
            allDetected: detected,
            problems,
            stats: {
                lines: code.split('\n').length,
                characters: code.length,
                tokens: code.split(/[\s\W]+/).length
            }
        };
    }
    
    // Common issues in any language
    static checkCommonIssues(code) {
        const issues = [];
        
        // Hardcoded credentials
        if (/password\s*=\s*['"][^'"]+['"]/gi.test(code)) {
            issues.push({ type: 'HARDCODED_PASSWORD', severity: 'CRITICAL' });
        }
        
        // TODO/FIXME comments
        const todos = code.match(/\/\/\s*TODO|\/\*\s*TODO|#\s*TODO|--\s*TODO/gi);
        if (todos) {
            issues.push({ type: 'TODO_COMMENTS', count: todos.length, severity: 'LOW' });
        }
        
        // Large functions (>100 lines)
        const functions = code.match(/(?:function|def|func|fn|sub|proc)\s+\w+/gi);
        if (functions && functions.length > 10) {
            issues.push({ type: 'TOO_MANY_FUNCTIONS', severity: 'INFO' });
        }
        
        return issues;
    }
}

