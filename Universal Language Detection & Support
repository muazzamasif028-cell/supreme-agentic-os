            'solidity': [/pragma solidity/m, /contract \w+/m, /function \w+\(/m, /msg\.sender/m],
            'php': [/^<\?php/m, /\$\w+/m, /->\w+/m],
            'ruby': [/def \w+/m, /end$/m, /puts /m, /\.each do/m],
        };
        
        return patterns[lang] || [];
    }
    
    // Get problem detection rules per language
    static getLanguageSpecificRules(lang) {
        const rules = {
            'javascript': {
                memoryLeak: /setInterval|addEventListener(?!.*removeEventListener)/g,
                asyncIssues: /await (?!.*try|.*catch)/g,
                undefinedError: /\.(\w+)\s*(?!.*\?\.)/g
            },
            'python': {
                memoryLeak: /while True:/g,
                importError: /import \w+\s*#.*missing/g,
                syntaxError: /:\s*$/gm
            },
            'java': {
                nullPointer: /\.\w+\(\)\s*(?!.*null\s*==)/g,
                memoryLeak: /new\s+\w+\s*\(\s*\)\s*(?!.*close\s*\(\s*\))/g,
                threadIssues: /Thread\.sleep/g
            },
            'rust': {
                ownershipError: /let\s+\w+\s*=\s*\w+;\s*\w+/g,
                borrowIssues: /&\w+\s+\w+/g,
                unsafeBlock: /unsafe\s*{/g
            }
        };
        
        return rules[lang] || {};
    }
    
    // Generate fix suggestion per language
    static getFixSuggestion(lang, problemType) {
        const fixes = {
