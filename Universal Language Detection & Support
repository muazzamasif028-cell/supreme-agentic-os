    // Get language syntax patterns
    static getLanguagePatterns(lang) {
        const patterns = {
            'python': [/^import \w+/m, /^from \w+ import/m, /def \w+\(/m, /:\s*$/m, /print\(/m],
            'javascript': [/const \w+ =/m, /let \w+ =/m, /function\s+\w+/m, /=>\s*{/m, /console\.log/m],
            'java': [/public class \w+/m, /public static void main/m, /System\.out\.println/m],
            'rust': [/fn \w+\(/m, /let mut \w+/m, /impl \w+/m, /::\w+/m],
            'go': [/package \w+/m, /func \w+\(/m, /:=/m],
            'html': [/<!DOCTYPE html>/i, /<html>/i, /<div/m, /<\/\w+>/m],
