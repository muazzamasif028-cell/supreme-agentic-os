    // Detect language from code
    static detectLanguage(code) {
        const features = this.extractFeatures(code);
        const scores = {};
        
        // Pattern matching for 7000+ languages
        for (const [lang, info] of Object.entries(this.LANG_DATABASE)) {
            let score = 0;
            
            // Check file extension hints
            if (features.extension && info.ext === features.extension) {
                score += 50;
            }
            
            // Check keywords
            const keywords = this.getLanguageKeywords(lang);
            const matchedKeywords = keywords.filter(kw => 
                features.tokens.includes(kw)
            );
            score += matchedKeywords.length * 10;
            
            // Check syntax patterns
            const patterns = this.getLanguagePatterns(lang);
            for (const pattern of patterns) {
                if (pattern.test(code)) score += 15;
            }
            
            if (score > 0) scores[lang] = score;
        }
        
        // Sort by confidence
        return Object.entries(scores)
            .sort((a, b) => b[1] - a[1])
            .slice(0, 5)
            .map(([lang, score]) => ({
                language: lang,
                confidence: Math.min(score, 100),
                info: this.LANG_DATABASE[lang]
            }));
    }
    
    // Extract code features
    static extractFeatures(code) {
        return {
            extension: code.match(/\.(\w+)$/)?.[1] || null,
            tokens: code.split(/[\s\W]+/).filter(t => t.length > 1),
            lines: code.split('\n'),
            firstLine: code.split('\n')[0]?.trim() || ''
        };
    }
    
