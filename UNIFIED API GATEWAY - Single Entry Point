const express = require('express');
const rateLimit = require('express-rate-limit');
const { orchestrator } = require('../orchestrator');

const router = express.Router();

// ============================================
// RATE LIMITING
// ============================================
const generalLimiter = rateLimit({
    windowMs: 15 * 60 * 1000, // 15 minutes
    max: 100,
    message: { error: 'Too many requests, try again later' }
});

const authLimiter = rateLimit({
    windowMs: 15 * 60 * 1000,
    max: 10,
    message: { error: 'Too many login attempts' }
});

const detectLimiter = rateLimit({
    windowMs: 1 * 60 * 1000, // 1 minute
    max: 30,
    message: { error: 'Detection rate limit reached' }
});

// Apply general limiter to all routes
router.use(generalLimiter);

// ============================================
// API DOCUMENTATION
// ============================================
router.get('/', (req, res) => {
    res.json({
        name: 'Supreme Problem Detector API',
        version: 'v1.0.0',
        status: 'LIVE',
        baseUrl: '/api/v1',
        endpoints: {
            health: 'GET /api/v1/health',
            auth: {
                signup: 'POST /api/v1/auth/signup',
                login: 'POST /api/v1/auth/login',
                profile: 'GET /api/v1/auth/profile'
            },
            detection: {
                quick: 'POST /api/v1/detect',
                full: 'POST /api/v1/solve',
                chip: 'POST /api/v1/chip-diagnose'
            },
            payment: {
                plans: 'GET /api/v1/payment/plans',
                subscribe: 'POST /api/v1/payment/subscribe',
                charge: 'POST /api/v1/payment/charge',
                history: 'GET /api/v1/payment/history'
            },
            admin: {
                stats: 'GET /api/v1/admin/stats',
                companies: 'GET /api/v1/admin/companies'
            }
        }
    });
});

// ============================================
// HEALTH CHECK
// ============================================
router.get('/health', async (req, res) => {
    const health = await orchestrator.healthCheck();
    res.json({
        status: 'OK',
        timestamp: new Date().toISOString(),
        ...health
    });
});

// ============================================
// AUTH ROUTES
// ============================================
router.post('/auth/signup', authLimiter, async (req, res) => {
    try {
        const { email, password, company } = req.body;
        
        if (!email || !password) {
            return res.status(400).json({ error: 'Email and password required' });
        }
        
        const result = await orchestrator.executePipeline('full', {
            action: 'signup',
            email,
            password,
            company
        });
        
        res.json({
            success: true,
            token: result.auth?.token,
            user: result.auth?.user,
            message: '✅ Account created! 🎁 First problem FREE!'
        });
        
    } catch (error) {
        res.status(400).json({ error: error.message });
    }
});

router.post('/auth/login', authLimiter, async (req, res) => {
    try {
        const { email, password } = req.body;
        
        if (!email || !password) {
            return res.status(400).json({ error: 'Email and password required' });
        }
        
        const result = await orchestrator.handleRequest('auth', {
            action: 'login',
            email,
            password
        });
        
        res.json({
            success: true,
            token: result.token,
            user: result.user,
            message: `✅ Welcome back, ${result.user.company || 'User'}!`
        });
        
    } catch (error) {
        res.status(401).json({ error: error.message });
    }
});

router.get('/auth/profile', async (req, res) => {
    try {
        const token = req.headers.authorization?.split(' ')[1];
        if (!token) return res.status(401).json({ error: 'Token required' });
        
        const result = await orchestrator.handleRequest('auth', {
            action: 'verify',
            token
        });
        
        res.json({ success: true, user: result.user });
        
    } catch (error) {
        res.status(401).json({ error: error.message });
    }
});

// ============================================
// DETECTION ROUTES
// ============================================
router.post('/detect', detectLimiter, async (req, res) => {
    try {
        const { problem, language, context } = req.body;
        
        if (!problem) {
            return res.status(400).json({ error: 'Problem description required' });
        }
        
        // Execute quick pipeline
        const result = await orchestrator.executePipeline('quick', {
            problem,
            language,
            context,
            source: 'api'
        });
        
        res.json({
            success: true,
            detection: result.detector,
            aiAnalysis: result.ai,
            prediction: result.precognition,
            timestamp: new Date().toISOString()
        });
        
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

router.post('/solve', async (req, res) => {
    try {
        const { problem, paymentMethodId } = req.body;
        const token = req.headers.authorization?.split(' ')[1];
        
        if (!problem) {
            return res.status(400).json({ error: 'Problem description required' });
        }
        
        // Execute full pipeline
        const result = await orchestrator.executePipeline('full', {
            problem,
            token,
            paymentMethodId,
            source: 'api'
        });
        
        res.json({
            success: true,
            detection: result.detector,
            aiAnalysis: result.ai,
            prediction: result.precognition,
            fix: result.executor,
            payment: result.payment,
            timestamp: new Date().toISOString(),
            message: result.payment?.free ? 
                '🎁 Solved with free credit!' : 
                `✅ Solved! Charged $${result.payment?.amount || 0}`
        });
        
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

router.post('/chip-diagnose', async (req, res) => {
    try {
        const { symptoms } = req.body;
        const os = require('os');
        
        const chipInfo = {
            model: os.cpus()[0]?.model || 'Unknown',
            cores: os.cpus().length,
            architecture: os.arch(),
            platform: os.platform(),
            memory: {
                total: Math.round(os.totalmem() / (1024 * 1024 * 1024)) + 'GB',
                free: Math.round(os.freemem() / (1024 * 1024 * 1024)) + 'GB'
            }
        };
        
        // Quick diagnostic
        const result = await orchestrator.executePipeline('quick', {
            problem: `CPU: ${chipInfo.model}, Symptoms: ${JSON.stringify(symptoms)}`,
            context: { chipInfo }
        });
        
        res.json({
            success: true,
            chip: chipInfo,
            diagnosis: result.detector,
            aiAnalysis: result.ai
        });
        
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

