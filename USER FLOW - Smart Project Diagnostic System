        this.diagnostic = new SmartProjectDiagnostic();
    }
    
    async runInteractive() {
        console.log('\n🤖 Welcome to Supreme Problem Detector!\n');
        console.log('=' .repeat(50));
        
        // Simulate user input
        const scenarios = [
            {
                input: "Mera React project bar bar crash ho rha hai. MongoDB se connection timeout aa rha. meri email ali@techstartup.com hai. VS Code pe bna rha hun.",
                description: "React app crash + DB timeout + VS Code"
            },
            {
                input: "Next.js project build fail ho rha bar bar. I'm using replit. Port 3000 already in use error. contact@mycompany.com",
                description: "Next.js build fail + Port conflict + Replit"
            },
            {
                input: "Node.js app memory leak se crash ho rha every 30 min. EC2 pe hosted hai. help@startup.pk",
                description: "Memory leak + AWS + Crash loop"
            }
        ];
        
        for (const scenario of scenarios) {
            console.log(`\n📥 User Input: "${scenario.input}"\n`);
            
            const result = await this.diagnostic.start(scenario.input);
            
            console.log('\n📊 DIAGNOSTIC RESULT:');
            console.log('='.repeat(50));
            console.log(`Email Status: ${result.emailVerified ? '✅ Verified' : '❌ Issues Found'}`);
            console.log(`Problems Found: ${result.report?.summary?.totalProblems || 0}`);
            console.log(`Critical: ${result.report?.summary?.critical || 0}`);
            console.log(`Recommendation: ${result.report?.recommendation}`);
            console.log('='.repeat(50));
            
            if (result.report?.problems?.length > 0) {
                console.log('\n🔧 QUICK FIXES:');
                result.report.problems
                    .filter(p => p.fix)
                    .slice(0, 2)
                    .forEach((p, i) => {
                        console.log(`\n${i+1}. ${p.type}: ${p.cause}`);
                        console.log(`   Solution: ${p.solution}`);
                        console.log(`   Fix:\n${p.fix}`);
                    });
            }
        }
    }
}

// ============================================
// EXPRESS API ENDPOINT
// ============================================
function setupDiagnosticRoute(app) {
    const diagnostic = new SmartProjectDiagnostic();
    
    app.post('/api/diagnose', async (req, res) => {
        const { problem } = req.body;
        
        if (!problem) {
            return res.status(400).json({ error: 'Please describe your problem' });
        }
        
        try {
            const result = await diagnostic.start(problem);
            res.json(result);
        } catch (error) {
            res.status(500).json({ error: error.message });
        }
    });
    
    console.log('✅ Diagnostic API ready: POST /api/diagnose');
}

