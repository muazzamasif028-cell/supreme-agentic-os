                        placeholder="Example: Mera React project bar bar crash ho rha hai. MongoDB connection timeout aa rha. VS Code pe bna rha hun..."></textarea>
                </div>
                
                <!-- Logs Input -->
                <div id="tab-logs" style="display:none;">
                    <textarea class="problem-input" id="logInput" 
                        placeholder="Paste your error logs / stack trace here...
[2024-01-15 14:30:00] ERROR: Connection timeout
at Object.connect (/app/db.js:42:15)..."></textarea>
                </div>
                
                <!-- File Upload -->
                <div id="tab-upload" style="display:none;">
                    <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                        <h3>📤 Click to Upload</h3>
                        <p>Upload .log, .txt, or .json files</p>
                        <input type="file" id="fileInput" accept=".log,.txt,.json" onchange="handleFileUpload(this)">
                    </div>
                    <div id="fileInfo" style="margin-top:10px;color:#888;"></div>
                </div>
                
                <div class="btn-group">
                    <button class="btn btn-primary" onclick="scanProblem()">🔍 Scan Problem</button>
                    <button class="btn btn-secondary" onclick="clearInput()">Clear</button>
                </div>
            </div>
            
            <!-- Results -->
            <div class="card" id="resultsCard" style="display:none;">
                <h3>📊 Scan Results</h3>
                <div id="resultsContent"></div>
            </div>
        </div>
    </div>
    
    <script>
        let currentTab = 'text';
        
        function switchTab(tab) {
            currentTab = tab;
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('tab-text').style.display = tab === 'text' ? 'block' : 'none';
            document.getElementById('tab-logs').style.display = tab === 'logs' ? 'block' : 'none';
            document.getElementById('tab-upload').style.display = tab === 'upload' ? 'block' : 'none';
        }
        
        function handleFileUpload(input) {
            const file = input.files[0];
            if (file) {
                document.getElementById('fileInfo').innerHTML = 
                    '📄 ' + file.name + ' (' + (file.size/1024).toFixed(1) + ' KB)';
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('problemInput').value = e.target.result;
                };
                reader.readAsText(file);
            }
        }
        
        async function scanProblem() {
            const input = currentTab === 'logs' ? 
                document.getElementById('logInput').value :
                document.getElementById('problemInput').value;
            
            if (!input.trim()) {
                alert('Please describe your problem or paste logs');
                return;
            }
            
            // Show loading
            const resultsCard = document.getElementById('resultsCard');
            const resultsContent = document.getElementById('resultsContent');
            resultsCard.style.display = 'block';
            resultsContent.innerHTML = '<div style="text-align:center;padding:30px;">🔄 Scanning... Please wait</div>';
            
            // Call API
            try {
                const response = await fetch('/api/diagnose', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ problem: input })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showResults(data.report);
                } else {
                    resultsContent.innerHTML = '<div style="color:#dc3545;">❌ ' + data.message + '</div>';
                }
            } catch (error) {
                resultsContent.innerHTML = '<div style="color:#dc3545;">❌ Error: ' + error.message + '</div>';
            }
        }
        
        function showResults(report) {
            const container = document.getElementById('resultsContent');
            
            let html = '';
            
            // Summary
            html += '<div class="stats-grid" style="margin-bottom:15px;">';
            html += '<div class="stat-card"><div class="value">' + report.summary.totalProblems + '</div><div class="label">Problems</div></div>';
            html += '<div class="stat-card"><div class="value">' + report.summary.critical + '</div><div class="label">Critical</div></div>';
            html += '<div class="stat-card"><div class="value">' + report.summary.high + '</div><div class="label">High</div></div>';
            html += '<div class="stat-card"><div class="value">' + (report.recommendation || 'Fix Ready') + '</div><div class="label">Action</div></div>';
            html += '</div>';
            
            // Problems
            if (report.problems && report.problems.length > 0) {
                report.problems.forEach((p, i) => {
                    html += '<div class="result-item ' + (p.severity || 'medium').toLowerCase() + '">';
                    html += '<div class="title">#' + (i+1) + ' ' + (p.type || 'Issue') + 
                            '<span class="severity-badge severity-' + (p.severity || 'MEDIUM') + '">' + (p.severity || 'MEDIUM') + '</span></div>';
                    html += '<div class="detail">' + (p.cause || p.message || '') + '</div>';
                    if (p.solution) html += '<div class="detail" style="color:#28a745;margin-top:5px;">💡 Fix: ' + p.solution + '</div>';
                    html += '</div>';
                });
            }
            
            // Fix button
            html += '<div style="text-align:center;margin-top:20px;">';
            html += '<button class="btn btn-fix" onclick="applyFix()">🔧 Apply Auto-Fix</button>';
            html += '<button class="btn btn-secondary" onclick="showDetails()">📋 Show Details</button>';
            html += '</div>';
            
            container.innerHTML = html;
        }
        
        function applyFix() {
            if (confirm('Apply suggested fixes? This may restart services.')) {
                alert('✅ Fix applied! Monitor for 5 minutes.');
            }
        }
        
        function showDetails() {
            alert('📋 Detailed report coming soon!');
        }
        
        function clearInput() {
            document.getElementById('problemInput').value = '';
            document.getElementById('logInput').value = '';
            document.getElementById('resultsCard').style.display = 'none';
        }
    </script>
</body>
</html>`;
}

