    // ==========================================
    // 1. LOG FILE ANALYZER
    // ==========================================
    async scanLogs(logInput) {
        console.log('\n📄 Scanning log files...');
        
        const results = {
            errors: [],
            warnings: [],
            patterns: [],
            summary: {}
        };
        
        // Parse log content
        const lines = typeof logInput === 'string' ? 
            logInput.split('\n') : 
            logInput;
        
        for (const line of lines) {
            // Detect error patterns
            if (this.isError(line)) {
                results.errors.push({
                    line: line,
                    timestamp: this.extractTimestamp(line),
                    type: this.classifyError(line),
                    severity: this.getSeverity(line),
                    source: this.extractSource(line)
                });
            }
            
            // Detect warnings
            if (this.isWarning(line)) {
                results.warnings.push({
                    line: line,
                    timestamp: this.extractTimestamp(line),
                    message: line.substring(0, 100)
                });
            }
        }
        
        // Find patterns
        results.patterns = this.findErrorPatterns(results.errors);
        
        // Summary
        results.summary = {
            totalLines: lines.length,
            errors: results.errors.length,
            warnings: results.warnings.length,
            errorRate: ((results.errors.length / lines.length) * 100).toFixed(2) + '%',
            topError: this.getTopError(results.errors),
            timeRange: this.getTimeRange(results.errors),
            recommendation: this.generateLogRecommendation(results)
        };
        
        return results;
    }
    
    isError(line) {
        const errorKeywords = [
            'ERROR', 'FATAL', 'CRITICAL', 'FAIL', 'EXCEPTION',
            'Error:', 'error:', 'err:', 'panic', 'traceback',
            'at Object.', 'at Function.', 'at Module.',
            'Cannot', 'Unable', 'Failed', 'Timeout'
        ];
        return errorKeywords.some(k => line.includes(k));
    }
    
    isWarning(line) {
        const warnKeywords = ['WARN', 'WARNING', 'warn:', 'DEPRECATED', 'deprecated'];
        return warnKeywords.some(k => line.includes(k));
    }
    
    classifyError(line) {
        if (line.includes('OutOfMemory') || line.includes('heap')) return 'MEMORY';
        if (line.includes('Timeout') || line.includes('timed out')) return 'TIMEOUT';
        if (line.includes('Connection') || line.includes('ECONNREFUSED')) return 'CONNECTION';
        if (line.includes('NullPointer') || line.includes('undefined')) return 'NULL_REFERENCE';
        if (line.includes('SQL') || line.includes('database')) return 'DATABASE';
        if (line.includes('Permission') || line.includes('EACCES')) return 'PERMISSION';
        if (line.includes('Disk') || line.includes('ENOSPC')) return 'DISK';
        if (line.includes('CPU') || line.includes('throttle')) return 'CPU';
        return 'UNKNOWN';
    }
    
    getSeverity(line) {
        if (line.includes('FATAL') || line.includes('CRITICAL')) return 'CRITICAL';
        if (line.includes('ERROR') || line.includes('FAIL')) return 'HIGH';
        if (line.includes('WARN')) return 'MEDIUM';
        return 'LOW';
    }
    
    extractTimestamp(line) {
        const patterns = [
            /(\d{4}-\d{2}-\d{2}\s\d{2}:\d{2}:\d{2})/,
            /(\d{2}\/\d{2}\/\d{4}\s\d{2}:\d{2}:\d{2})/,
            /\[(\d{2}\/\w+\/\d{4}:\d{2}:\d{2}:\d{2})/,
            /(\w+\s+\d+\s+\d{2}:\d{2}:\d{2})/
        ];
        
        for (const pattern of patterns) {
            const match = line.match(pattern);
            if (match) return match[1];
        }
        return null;
    }
    
    extractSource(line) {
        const match = line.match(/at\s+(.+?)\s+\((.+?):(\d+):(\d+)\)/);
        if (match) return { file: match[2], line: match[3], function: match[1] };
        
        const fileMatch = line.match(/([\w\/\.-]+\.\w+):(\d+)/);
        if (fileMatch) return { file: fileMatch[1], line: fileMatch[2] };
        
        return null;
    }
    
    findErrorPatterns(errors) {
        const patterns = [];
        const errorCounts = {};
        
        errors.forEach(e => {
            const key = e.type;
            errorCounts[key] = (errorCounts[key] || 0) + 1;
        });
        
        // Find most frequent errors
        const sorted = Object.entries(errorCounts)
            .sort((a, b) => b[1] - a[1])
            .slice(0, 5);
        
        sorted.forEach(([type, count]) => {
            patterns.push({
                type,
                count,
                frequency: count > 10 ? 'HIGH' : count > 3 ? 'MEDIUM' : 'LOW',
                recommendation: this.getErrorRecommendation(type)
            });
        });
        
        return patterns;
    }
    
    getErrorRecommendation(type) {
        const recs = {
            'MEMORY': 'Increase memory limit or fix memory leak',
            'TIMEOUT': 'Increase timeout or optimize slow operation',
            'CONNECTION': 'Check if service is running and accessible',
            'NULL_REFERENCE': 'Add null checks before accessing properties',
            'DATABASE': 'Check database connection and query performance',
            'PERMISSION': 'Fix file/directory permissions',
            'DISK': 'Free up disk space or increase storage',
            'CPU': 'Optimize CPU-intensive operations or add caching'
        };
        return recs[type] || 'Investigate error source';
    }
    
    getTopError(errors) {
        if (errors.length === 0) return 'No errors found';
        const first = errors[0];
        return {
            type: first.type,
            severity: first.severity,
            count: errors.filter(e => e.type === first.type).length
        };
    }
    
    getTimeRange(errors) {
        const timestamps = errors
            .map(e => e.timestamp)
            .filter(t => t)
            .map(t => new Date(t))
            .sort((a, b) => a - b);
        
        if (timestamps.length < 2) return 'Insufficient data';
        
        return {
            start: timestamps[0].toISOString(),
            end: timestamps[timestamps.length - 1].toISOString(),
            duration: Math.round((timestamps[timestamps.length - 1] - timestamps[0]) / 1000) + 's'
        };
    }
    
    generateLogRecommendation(results) {
        if (results.errors.length === 0) return '✅ No errors in logs';
        if (results.errors.length > 100) return '🚨 Too many errors - Immediate action required!';
        if (results.errors.length > 10) return '⚠️ Multiple errors found - Fix top errors first';
        return 'Few errors found - Low priority fix';
    }
    
    // ==========================================
    // 2. GITHUB REPO SCANNER
    // ==========================================
    async scanGitHub(repoUrl) {
        console.log(`\n🔍 Scanning GitHub repo: ${repoUrl}`);
        
        // Simulated GitHub scan results
        const results = {
            repo: repoUrl,
            issues: [],
            codeQuality: {},
            dependencies: {},
            security: {}
        };
        
        // Check for common issues in repo
        const commonIssues = [
            { file: 'package.json', check: 'dependencies', issue: 'Outdated packages' },
            { file: '.env', check: 'exposed', issue: '.env file committed to repo!' },
            { file: 'node_modules', check: 'committed', issue: 'node_modules should not be in repo' },
            { file: 'test/', check: 'missing', issue: 'No test files found' },
            { file: 'README.md', check: 'missing', issue: 'No README documentation' }
        ];
        
        results.issues = commonIssues;
        
        // Dependencies check
        results.dependencies = {
            total: 45,
            outdated: 12,
            vulnerable: 3,
            recommendation: 'Run: npm audit fix && npm update'
        };
        
        // Code quality
        results.codeQuality = {
            lintingErrors: 23,
            typeErrors: 5,
            codeSmells: 15,
            duplication: '8%',
            recommendation: 'Fix linting errors and reduce duplication'
        };
        
        return results;
    }
    
    // ==========================================
    // 3. SERVER METRICS SCANNER
    // ==========================================
    async scanServerMetrics(metrics) {
        console.log('\n📊 Scanning server metrics...');
        
        const results = {
            timestamp: new Date().toISOString(),
            metrics: metrics,
            alerts: [],
            health: 'UNKNOWN'
        };
        
        // CPU Check
        if (metrics.cpu > 90) {
            results.alerts.push({
                type: 'CPU_CRITICAL',
                message: `CPU at ${metrics.cpu}% - Critical!`,
                severity: 'CRITICAL',
                action: 'Scale up or optimize CPU usage'
            });
        } else if (metrics.cpu > 70) {
            results.alerts.push({
                type: 'CPU_HIGH',
                message: `CPU at ${metrics.cpu}% - Monitor`,
                severity: 'WARNING'
            });
        }
        
        // Memory Check
        if (metrics.memory > 90) {
            results.alerts.push({
                type: 'MEMORY_CRITICAL',
                message: `Memory at ${metrics.memory}% - OOM risk!`,
                severity: 'CRITICAL',
                action: 'Clear cache and check for leaks'
            });
        }
        
        // Disk Check
        if (metrics.disk > 90) {
            results.alerts.push({
                type: 'DISK_CRITICAL',
                message: `Disk at ${metrics.disk}% - Clean up required`,
                severity: 'CRITICAL'
            });
        }
        
        // Determine health
        const criticalAlerts = results.alerts.filter(a => a.severity === 'CRITICAL');
        if (criticalAlerts.length > 0) {
            results.health = 'UNHEALTHY';
        } else if (results.alerts.length > 0) {
            results.health = 'DEGRADED';
        } else {
            results.health = 'HEALTHY';
        }
        
        return results;
    }
    
    // ==========================================
    // 4. DATABASE SCANNER
    // ==========================================
    async scanDatabase(dbMetrics) {
        console.log('\n🗄️ Scanning database...');
        
        return {
            status: dbMetrics.connected ? 'CONNECTED' : 'DISCONNECTED',
            connectionPool: {
                active: dbMetrics.activeConnections || 0,
                idle: dbMetrics.idleConnections || 0,
                max: dbMetrics.maxConnections || 100,
                usage: dbMetrics.activeConnections ? 
                    ((dbMetrics.activeConnections / dbMetrics.maxConnections) * 100).toFixed(0) + '%' : '0%'
            },
            slowQueries: dbMetrics.slowQueries || [],
            locks: dbMetrics.locks || 0,
            recommendations: this.getDatabaseRecommendations(dbMetrics)
        };
    }
    
    getDatabaseRecommendations(metrics) {
        const recs = [];
        if (!metrics.connected) recs.push('Database is DOWN - Check connection');
        if (metrics.activeConnections > metrics.maxConnections * 0.8) recs.push('Connection pool near limit');
        if (metrics.slowQueries?.length > 0) recs.push('Optimize slow queries');
        if (metrics.locks > 5) recs.push('High lock contention detected');
        return recs;
    }
    
    // ==========================================
    // 5. DOCKER CONTAINER SCANNER
    // ==========================================
    async scanDocker(containerData) {
        console.log('\n🐳 Scanning Docker containers...');
        
        const results = {
            containers: containerData.containers || [],
            issues: [],
            summary: {}
        };
        
        for (const container of results.containers) {
            // Check container health
            if (container.status !== 'running') {
                results.issues.push({
                    container: container.name,
                    issue: `Container ${container.status}`,
                    severity: 'CRITICAL',
                    action: `docker start ${container.name}`
                });
            }
            
            // Check resource limits
            if (container.cpuUsage > 90) {
                results.issues.push({
                    container: container.name,
                    issue: `CPU at ${container.cpuUsage}%`,
                    severity: 'HIGH'
                });
            }
            
            // Check restart count
            if (container.restartCount > 5) {
                results.issues.push({
                    container: container.name,
                    issue: `Restarted ${container.restartCount} times - Crash loop!`,
                    severity: 'CRITICAL',
                    action: 'Check logs: docker logs ' + container.name
                });
            }
        }
        
        results.summary = {
            total: results.containers.length,
            running: results.containers.filter(c => c.status === 'running').length,
            issues: results.issues.length
        };
        
        return results;
    }
}

