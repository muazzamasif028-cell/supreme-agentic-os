    async executePipeline(pipelineName, input) {
        const pipeline = this.pipelines.get(pipelineName);
        if (!pipeline) throw new Error(`Pipeline not found: ${pipelineName}`);
        
        console.log(`\n🔄 EXECUTING PIPELINE: ${pipelineName}`);
        const startTime = Date.now();
        
        let context = { ...input, startTime };
        
        for (const layerName of pipeline) {
            const layer = this.findLayer(layerName);
            if (layer) {
                console.log(`   ⚡ Layer: ${layer.name}`);
                // In production: actual layer execution
            }
        }
        
        context.completedAt = Date.now();
        context.duration = context.completedAt - startTime;
        
        this.emit('pipeline:completed', { pipeline: pipelineName, duration: context.duration });
        
        return context;
    }
    
    findLayer(name) {
        for (const [num, layer] of this.layers) {
            if (layer.name.includes(name) || layer.name === name) {
                return { num, ...layer };
            }
        }
        return null;
    }
    
