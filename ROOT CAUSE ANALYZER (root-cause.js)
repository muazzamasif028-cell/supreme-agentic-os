// ============================================
// ROOT CAUSE ANALYZER
// Finds WHY problem happened
// ============================================

class RootCauseAnalyzer {
    
    constructor() {
        this.causalChains = new Map();
        this.knownCauses = this.loadKnownCauses();
    }
    
    // Main: Find root cause
    async analyze(problem) {
        console.log(`\n🔍 Root Cause Analysis: ${problem.id}`);
        
        // Step 1: Collect evidence
        const evidence = this.collectEvidence(problem);
        
        // Step 2: Build causal chain
        const chains = this.buildCausalChains(evidence);
        
        // Step 3: Score each cause
        const scored = chains.map(c => ({
            ...c,
            confidence: this.calculateConfidence(c, evidence),
            impact: this.assessImpact(c)
        }));
        
        // Step 4: Find root cause (highest score)
        const rootCause = scored.sort((a, b) => b.confidence - a.confidence)[0];
        
        // Step 5: Generate prevention
        const prevention = this.generatePrevention(rootCause);
        
        return {
            problemId: problem.id,
            rootCause,
            alternativeCauses: scored.slice(1, 3),
            evidence,
            prevention,
            timeToDetect: '2ms'
        };
    }
    
    collectEvidence(problem) {
        return {
            symptoms: [problem.description, ...(problem.errors || [])],
            timing: problem.timestamp,
            environment: problem.environment || 'production',
            recentChanges: problem.recentChanges || [],
            stackTrace: problem.stackTrace || '',
            metrics: problem.metrics || {},
            logs: problem.logs || []
        };
    }
    
    buildCausalChains(evidence) {
        const chains = [];
        const text = JSON.stringify(evidence).toLowerCase();
        
        // Database issues
        if (text.includes('timeout') || text.includes('connection')) {
            chains.push({
                cause: 'DATABASE_OVERLOAD',
                chain: ['High traffic', 'Connection pool exhausted', 'Query timeout', 'Service unavailable'],
                probability: 85
            });
        }
        
        // Memory issues
        if (text.includes('memory') || text.includes('heap') || text.includes('oom')) {
            chains.push({
                cause: 'MEMORY_LEAK',
                chain: ['Object not released', 'Heap grows', 'GC pressure', 'OOM error', 'Crash'],
                probability: 90
            });
        }
        
        // Deployment issues
        if (text.includes('deploy') || text.includes('release')) {
            chains.push({
                cause: 'BAD_DEPLOYMENT',
                chain: ['New version deployed', 'Config mismatch', 'Dependency conflict', 'Service crash'],
                probability: 75
            });
        }
        
        // Network issues
        if (text.includes('dns') || text.includes('network') || text.includes('timeout')) {
            chains.push({
                cause: 'NETWORK_FAILURE',
                chain: ['DNS resolution failed', 'Service unreachable', 'Request timeout', 'Cascade failure'],
                probability: 70
            });
        }
        
        if (chains.length === 0) {
            chains.push({
                cause: 'UNKNOWN',
                chain: ['Insufficient data', 'Manual investigation required'],
                probability: 30
            });
        }
        
        return chains;
    }
    
    calculateConfidence(cause, evidence) {
        let score = cause.probability;
        
        // Boost if stack trace matches
        if (evidence.stackTrace && evidence.stackTrace.includes(cause.cause)) {
            score += 20;
        }
        
        // Boost if metrics confirm
        if (evidence.metrics[cause.cause.toLowerCase()]) {
            score += 15;
        }
        
        // Boost if recent changes related
        if (evidence.recentChanges.some(c => cause.cause.includes(c))) {
            score += 10;
        }
        
        return Math.min(score, 100);
    }
    
    assessImpact(cause) {
        const impacts = {
            'DATABASE_OVERLOAD': { severity: 'CRITICAL', affectedUsers: 'ALL', revenue: 'HIGH' },
            'MEMORY_LEAK': { severity: 'HIGH', affectedUsers: 'ALL', revenue: 'MEDIUM' },
            'BAD_DEPLOYMENT': { severity: 'HIGH', affectedUsers: 'ALL', revenue: 'HIGH' },
            'NETWORK_FAILURE': { severity: 'CRITICAL', affectedUsers: 'ALL', revenue: 'CRITICAL' }
        };
        return impacts[cause.cause] || { severity: 'MEDIUM', affectedUsers: 'SOME' };
    }
    
    generatePrevention(rootCause) {
        const preventions = {
            'DATABASE_OVERLOAD': [
                'Add connection pooling',
                'Implement circuit breaker',
                'Set up read replicas',
                'Add query caching'
            ],
            'MEMORY_LEAK': [
                'Add memory limits',
                'Implement object pooling',
                'Add periodic restarts',
                'Set up memory monitoring'
            ],
            'BAD_DEPLOYMENT': [
                'Implement canary deployments',
                'Add automated rollback',
                'Set up health checks',
                'Use blue-green deployment'
            ],
            'NETWORK_FAILURE': [
                'Add DNS failover',
                'Implement retry logic',
                'Set up multi-region',
                'Add circuit breaker'
            ]
        };
        
        return preventions[rootCause.cause] || ['Monitor and investigate'];
    }
    
    loadKnownCauses() {
        return new Map([
            ['high_cpu', { root: 'INFINITE_LOOP', fix: 'Add break condition' }],
            ['slow_response', { root: 'MISSING_CACHE', fix: 'Add Redis cache' }],
            ['crash', { root: 'NULL_POINTER', fix: 'Add null check' }]
        ]);
    }
}

module.exports = { RootCauseAnalyzer };

