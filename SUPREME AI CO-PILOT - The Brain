    // ==========================================
    // INITIALIZE FOR USER
    // ==========================================
    async initForUser(user) {
        this.user = user;
        
        // Detect user persona
        const persona = this.detectPersona(user);
        
        // Load personalized context
        this.context = {
            persona,
            company: user.company,
            tier: user.tier,
            credits: user.credits,
            role: user.role,
            firstTime: !user.lastLogin,
            recentProblems: await this.getRecentProblems(user.id),
            suggestedFeatures: this.getSuggestedFeatures(persona)
        };
        
        return this.generateWelcome();
    }
    
    // ==========================================
    // DETECT USER PERSONA
    // ==========================================
    detectPersona(user) {
        const email = user.email?.toLowerCase() || '';
        const role = user.role || '';
        
        if (email.includes('dev') || email.includes('engineer') || role === 'developer') {
            return 'DEVELOPER';
        }
        if (email.includes('admin') || email.includes('cto') || email.includes('ceo') || role === 'admin') {
            return 'ADMIN';
        }
        if (email.includes('finance') || email.includes('billing')) {
            return 'FINANCE';
        }
        if (email.includes('security') || email.includes('infosec')) {
            return 'SECURITY';
        }
        
        return 'GENERAL';
    }
    
