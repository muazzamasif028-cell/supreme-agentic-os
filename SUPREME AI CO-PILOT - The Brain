                '2. Watch AI analyze it instantly',
                '3. Get 3 solution options with confidence scores',
                '4. Apply fix (FREE - first one!)',
                '5. See results: Before vs After'
            ]
        };
        
        return steps[scenario] || ['Describe your problem', 'AI will guide you'];
    }
    
    // ==========================================
    // SUGGEST BASED ON BEHAVIOR
    // ==========================================
    async suggest(userId) {
        const recent = await this.getRecentProblems(userId);
        
        // If user detected CPU issues 3 times, suggest Ghost Mode
        const cpuIssues = recent.filter(p => p.type === 'HIGH_CPU');
        if (cpuIssues.length >= 3) {
            return {
                message: "I notice you've had CPU issues 3 times recently. Enable Ghost Mode and it will handle CPU spikes AUTOMATICALLY - you won't even know they happened!",
                action: 'Enable Ghost Mode',
                path: '/ghost'
            };
        }
        
        // If user never tried workspace
        if (!recent.some(p => p.source === 'workspace')) {
            return {
                message: "You haven't tried your personalized Workspace IDE yet! It auto-adapts to your role and supports 7000+ languages. Code, scan, fix - all in one place.",
                action: 'Open Workspace',
                path: '/workspace'
            };
        }
        
        return null;
    }
    
