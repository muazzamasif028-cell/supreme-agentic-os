// ============================================
// EXPRESS MIDDLEWARE
// ============================================
function copilotMiddleware(req, res, next) {
    req.copilot = new SupremeCoPilot();
    next();
}

// ============================================
// API ROUTES
// ============================================
function setupCopilotRoutes(app) {
    const copilot = new SupremeCoPilot();
    
    // Get welcome message
    app.get('/api/copilot/welcome', async (req, res) => {
        const user = req.user || { name: 'Guest', role: 'user', tier: 'FREE' };
        const welcome = await copilot.initForUser(user);
        res.json(welcome);
    });
    
    // Ask copilot
    app.post('/api/copilot/ask', async (req, res) => {
        const response = await copilot.respond(req.body.question);
        res.json(response);
    });
    
    // Get suggestions
    app.get('/api/copilot/suggest', async (req, res) => {
        const suggestion = await copilot.suggest(req.user?.id);
        res.json(suggestion);
    });
    
    // Get guided tour
    app.get('/api/copilot/tour', (req, res) => {
        res.json(copilot.getGuidedTour());
    });
    
    console.log('✅ Supreme Co-Pilot Routes Ready');
}

