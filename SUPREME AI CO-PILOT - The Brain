    // ==========================================
    // GUIDED RESPONSE TO USER INPUT
    // ==========================================
    async respond(userInput) {
        const input = (userInput || '').toLowerCase();
        
        // Find matching scenario
        for (const [key, scenario] of Object.entries(this.platform.scenarios)) {
            if (scenario.trigger.some(t => input.includes(t))) {
                return {
                    message: scenario.response,
                    action: scenario.action,
                    features: this.getRelevantFeatures(key),
                    nextSteps: this.getNextSteps(key, this.context.persona)
                };
            }
        }
        
        // Default: guide to detection
        return {
            message: "I'm here to help! Describe your problem, and I'll guide you to the right solution. You can also explore: /detect (find problems), /workspace (your IDE), /dashboard (metrics), or /ghost (auto-fix).",
            action: 'Describe problem',
            features: ['detection', 'workspace'],
            nextSteps: ['Tell me what issue you have', 'I will show you the exact fix']
        };
    }
    
    // ==========================================
    // GET RELEVANT FEATURES
    // ==========================================
    getRelevantFeatures(scenario) {
        const mapping = {
            serverDown: ['detection', 'ghost', 'dashboard'],
            slowPerformance: ['detection', 'precognition', 'workspace'],
            securityConcern: ['detection', 'audit', 'ghost'],
            billingQuestion: ['pricing', 'billing'],
            newToPlatform: ['detection', 'workspace', 'dashboard']
        };
        
        return mapping[scenario] || ['detection'];
    }
    
    // ==========================================
    // GET NEXT STEPS
    // ==========================================
    getNextSteps(scenario, persona) {
        const steps = {
            serverDown: [
                '1. Go to /detect immediately',
                '2. Describe: "Server/App is DOWN"',
                '3. AI finds root cause in < 1 second',
